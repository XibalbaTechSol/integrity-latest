# Copy to .env and fill in real values for local dev. Never commit a
# populated .env (see .gitignore). All of these can also be set as plain
# environment variables, which always take precedence over
# ~/.integrity-cli/config.json -- see integrity_cli/config.py.

# integrity-oracle's HTTP address (docs/INTERFACE_CONTRACT.md section 2 default)
ORACLE_URL=http://localhost:8080

# bcc_middleware's HTTP address (docs/INTERFACE_CONTRACT.md section 2 default)
BCC_MIDDLEWARE_URL=http://localhost:8000

# Bearer token sent as `Authorization: Bearer <token>` to both services above.
# No default is shipped on purpose -- set a real value here, or leave unset
# for unauthenticated local dev if the services you're talking to allow it.
AUTH_TOKEN=

# "local" relaxes the check that refuses obviously-fake AUTH_TOKEN values
# (e.g. "mock_demo_token"). Set this to anything else ("staging", "prod",
# etc.) in any environment where a placeholder token must never be accepted.
ENVIRONMENT=local
