# Copy to .env for local dev. Never commit a populated .env (see repo-root .gitignore).

# --- Cross-package shared vars (docs/INTERFACE_CONTRACT.md §3) ---
OPA_URL=http://localhost:8181
ORACLE_URL=http://localhost:8080
RPC_URL=http://localhost:8545
CHAIN_ID=31337
DEPLOYMENTS_FILE=../deployments.local.json

# --- OPA ---
OPA_PACKAGE_PATH=/v1/data/integrity/bcc
OPA_TIMEOUT_SECONDS=3.0

# --- Commitment freshness ---
BCC_MAX_AGE_MS=60000

# --- Circuit breaker ---
BCC_CB_VIOLATION_THRESHOLD=3
BCC_CB_LOCKOUT_SECONDS=900

# --- On-chain BAA check ---
BAA_CONTRACT_NAME=SmartBAA

# --- Merkle anchoring ---
STATE_ANCHOR_CONTRACT_NAME=StateAnchor
BCC_MERKLE_BATCH_SIZE=8
# Dev-only anvil default account #0 private key -- NEVER a real key.
ANCHOR_SIGNER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
