# Copy to .env for local dev. Never commit a populated .env (see repo-root .gitignore).

# --- Cross-package shared vars (docs/INTERFACE_CONTRACT.md §3) ---
OPA_URL=http://localhost:8181
ORACLE_URL=http://localhost:8080
RPC_URL=http://localhost:8545
CHAIN_ID=31337
DEPLOYMENTS_FILE=../deployments.local.json

# --- OPA ---
OPA_PACKAGE_PATH=/v1/data/integrity/bcc
OPA_TIMEOUT_SECONDS=3.0

# --- Commitment freshness ---
BCC_MAX_AGE_MS=60000

# --- Circuit breaker ---
BCC_CB_VIOLATION_THRESHOLD=3
BCC_CB_LOCKOUT_SECONDS=900

# --- On-chain BAA check ---
# Must be SmartBAAFactory specifically (implements isBAAActive); the
# per-pair SmartBAA escrow instances it creates do not implement it.
BAA_CONTRACT_NAME=SmartBAAFactory

# --- Merkle anchoring ---
STATE_ANCHOR_CONTRACT_NAME=StateAnchor
BCC_MERKLE_BATCH_SIZE=8
# Dev-only anvil default account #0 private key -- NEVER a real key.
ANCHOR_SIGNER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- Reputation sync / slashing (app/reputation.py, app/scoring_loop.py) ---
# Falls back to ANCHOR_SIGNER_PRIVATE_KEY when unset -- see app/reputation.py's
# module docstring for why that's correct on today's single-operator testnet.
# Set this explicitly once production key-separation happens.
REPUTATION_SIGNER_PRIVATE_KEY=
SCORE_SYNC_ENABLED=true
SCORE_SYNC_INTERVAL_SECONDS=300
DISPUTE_ENABLED=true
DISPUTE_MIN_EVENTS=5
DISPUTE_FLAGGED_RATIO_THRESHOLD=0.5
DISPUTE_LOOKBACK_BUCKET=1h
DISPUTE_STAKE_BPS=1000
DISPUTE_COOLDOWN_SECONDS=86400
