# ============================================================
# Integrity Protocol — root .env (gitignored)
# Copy this to .env and fill in the values for your target network.
#
# docker-compose reads this file automatically. The oracle-backend
# service passes RPC_URL, CHAIN_ID, and DEPLOYMENTS_FILE through
# to the Rust oracle — change these three to switch networks.
# ============================================================

# ── Target network ───────────────────────────────────────────
# Local anvil (default — used by `make chain` and all unit tests):
#   RPC_URL=http://localhost:8545
#   CHAIN_ID=31337
#   DEPLOYMENTS_FILE=../deployments.local.json
#
# Base Sepolia (live stack):
#   RPC_URL=https://sepolia.base.org          # free public endpoint, rate-limited
#   RPC_URL=https://base-sepolia.g.alchemy.com/v2/<YOUR_KEY>   # Alchemy (recommended)
#   CHAIN_ID=84532
#   DEPLOYMENTS_FILE=../deployments.baseSepolia.json

RPC_URL=https://sepolia.base.org
CHAIN_ID=84532
DEPLOYMENTS_FILE=../deployments.baseSepolia.json

# ── Signing keys (dev/testnet only — never commit real values) ─
# Required by the demo scenario engine (integrity-mvp/demo/) and
# the CLI for on-chain registration. Not needed to run the oracle
# in read-only mode.
FUNDER_PRIVATE_KEY=
DEPLOYER_PRIVATE_KEY=
ORACLE_SIGNER_PRIVATE_KEY=
GOVERNANCE_PRIVATE_KEY=
RESOLVER_PRIVATE_KEY=
INTEGRITY_WALLET_PASSWORD=

# ── Base Sepolia RPC (also used by foundry scripts) ───────────
# Same value as RPC_URL above — foundry.toml references this name
# directly in its [rpc_endpoints] table.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
