# Copy to .env for local dev / testnet deploys. Never commit a populated .env (see
# repo-root .gitignore). See docs/INTERFACE_CONTRACT.md §1-3 for the full toolchain and
# shared env var reference.

# ── Testnet: Base Sepolia (chainId 84532) ──────────────────────────────────────
# Base's own public RPC. Fine for occasional deploys/reads; if you're doing anything
# high-frequency (the oracle's live chain client, batch anchoring), get a dedicated
# Alchemy/Infura endpoint instead — the public endpoint rate-limits aggressively.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# ── Funder / deployer ───────────────────────────────────────────────────────────
# The wallet that (a) deploys every singleton + clone-implementation contract below,
# and (b) at agent-registration time, seeds each new agent's freshly-generated EVM
# wallet with enough test ETH to run its own 4-transaction self-deploy sequence (see
# the "Agent Primitives" section of the interface contract). MUST be 0x-prefixed hex
# — forge's `vm.envUint` rejects a bare hex string without the prefix.
# NEVER a real/mainnet key — this is a testnet-only faucet wallet.
FUNDER_PRIVATE_KEY=

# ── Protocol-held roles ──────────────────────────────────────────────────────────
# Passed into AgentPrimitivesFactory's constructor and baked into every agent's
# cloned primitives at initialize() time — see AgentPrimitivesFactory.sol's NatSpec
# for why these are kept distinct from the registering agent's own key. All four
# default to the funder/deployer address if left blank, which is fine for a single-
# operator testnet deployment; a production deployment should use separate keys
# (especially GOVERNANCE_ADDRESS/DISPUTER_ADDRESS, which arbitrate slashing disputes
# against agents and must not be the same key that deploys/administers everything
# else).
ORACLE_SIGNER_ADDRESS=
DISPUTER_ADDRESS=
GOVERNANCE_ADDRESS=
ARBITRATOR_ADDRESS=

# ── Etherscan/Basescan (optional, for `forge verify-contract`) ──────────────────
BASESCAN_API_KEY=
