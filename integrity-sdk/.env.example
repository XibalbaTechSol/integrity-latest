# Copy to .env for local dev. Never commit a populated .env (see root .gitignore).

# Shared endpoint names — must match docs/INTERFACE_CONTRACT.md §3 exactly,
# other packages read the same variable names.
OPA_URL=http://localhost:8181
BCC_MIDDLEWARE_URL=http://localhost:8000
ORACLE_URL=http://localhost:8080

# Where this agent's DID keypair + document are persisted.
INTEGRITY_DID_HOME=~/.integrity/did

# OTel collector for telemetry export (optional; SDK degrades gracefully if unset/unreachable).
INTEGRITY_OTLP_ENDPOINT=localhost:4317
