# integrity-oracle's HTTP API (see integrity-oracle/backend/src/config.rs)
VITE_ORACLE_URL=http://localhost:8080

# integrity-userapi's HTTP API (see integrity-userapi/app/config.py)
VITE_USERAPI_URL=http://localhost:8090

# Which network's deployments.<network>.json this app reads addresses from.
# 84532 = Base Sepolia (default, matches deployments.baseSepolia.json).
# 31337 = local anvil (matches deployments.local.json, use with `make chain`).
VITE_CHAIN_ID=84532

# Set to "true" once you've run `scripts/seed_mock_data.py` (see that file's
# docstring) to register a handful of real test agents/a real market against
# your local chain+oracle for UI testing. This is a DISPLAY-ONLY flag read
# by SettingsPage's "Developer" panel — it never triggers any write itself
# (that requires the funder key, which must never reach the browser bundle;
# see the script's own docstring for why it must run outside integrity-mvp).
VITE_MOCK_MODE=false

# Dev/demo-only auto-login — see src/components/DevAutoLogin.tsx. When both
# are set (in .env, NOT here) and no session token exists, the dashboard logs
# in as this real userapi account on startup, so demo/manual-test runs are
# signed in as admin by default without visiting Settings. It calls the same
# real POST /auth/login the Settings form does — a genuine JWT session, not a
# bypass. Leave these UNSET for any real deployment; the profile then shows an
# honest "Sign in" state. (Credentials live in .env, which is git-ignored and
# whose own header warns it must never ship as-is.)
# VITE_DEV_AUTO_LOGIN_EMAIL=admin@xibalba.dev
# VITE_DEV_AUTO_LOGIN_PASSWORD=change-me
